import { useState, useEffect, useRef } from "react";
import { motion, AnimatePresence, useScroll, useTransform } from 'framer-motion';
import { useMagnetic } from './hooks/useMagnetic.js';
import TransitionWrapper from './components/TransitionWrapper.jsx';
import "./index.css";

/* ============================================================
   FYNOVO — Teal #005F7A · Enhanced Animations with Framer Motion + CSS
   ============================================================ */

function useReveal(t = 0.1) {
  const ref = useRef(null);
  const [on, setOn] = useState(false);
  useEffect(() => {
    const el = ref.current; if (!el) return;
    const obs = new IntersectionObserver(
      ([e]) => { if (e.isIntersecting) { setOn(true); obs.disconnect(); } },
      { threshold: t }
    );
    obs.observe(el); return () => obs.disconnect();
  }, [t]);
  return [ref, on];
}
function R({ c = "r", d = "", children, style = {} }) {
  const [ref, on] = useReveal();
  return <div ref={ref} className={`${c} ${d} ${on ? "on" : ""}`} style={style}>{children}</div>;
}

