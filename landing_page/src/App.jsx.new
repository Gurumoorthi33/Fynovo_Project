      <motion.div className="parallax-blend" style={{ position: "absolute", bottom: 40, left: -100, width: 400, height: 400, borderRadius: "50%", background: "radial-gradient(circle, var(--primary-bg) 0%, transparent 70%)", style: { y: y2 }, pointerEvents: "none", zIndex: 0 }} />

      <TransitionWrapper>
        <div className="ticker">
          <div className="ticker-inner">
            {[...Array(3)].flatMap((_, pass) => ["GST AUTO-CALC", "SHOPIFY SYNC", "LIVE NSE FEED", "TDS TRACKING", "5-YR FORECAST", "AI ADVISOR", "RAZORPAY LINKED", "AUDIT TRAIL", "GROQ LLAMA 3.3", "MULTI-TENANT"].map((t, i) => <span key={`${pass}-${i}`} className={`ticker-item${i % 4 === 0 ? " hi" : ""}`}>{t}</span>))}
          </div>
        </div>
      </TransitionWrapper>

      <div style={{ display: "grid", gridTemplateColumns: "1fr 540px", flex: 1, maxWidth: "var(--max)", margin: "0 auto", width: "100%", padding: "60px 80px", gap: 64, alignItems: "center", position: "relative", zIndex: 1 }}>
        <motion.div style={{ display: "flex", flexDirection: "column" }} initial={{ opacity: 0 }} animate={{ opacity: 1 }} transition={{ staggerChildren: 0.1 }}>
          <R>
            <motion.div className="badge glow-hover" whileHover={{ scale: 1.05 }}><motion.span className="badge-dot" animate={{ scale: [1, 1.5, 1] }} transition={{ repeat: Infinity, duration: 2 }} />Financial Intelligence Platform</motion.div>
          </R>
          <R c="r" d="d1">
            <motion.h1 className="display" style={{ fontSize: "clamp(48px,6vw,82px)", marginBottom: 24 }} initial={{ opacity: 0, y: 30 }} whileInView={{ opacity: 1, y: 0 }} transition={{ duration: 0.8 }}>
              Automates Your<br />
              <span className="text-gradient">Taxes, Assets</span><br />
              &amp; Cashflow.
            </motion.h1>
          </R>
          <R c="r" d="d2">
            <motion.p className="body-lg" style={{ maxWidth: 460, marginBottom: 36 }} initial={{ opacity: 0, x: -20 }} whileInView={{ opacity: 1, x: 0 }}>
              Fynovo is the operating layer for your finances. It connects every rupee across platforms, computes your tax position in real time, and sends you AI-driven moves — before your CA does.
            </motion.p>
          </R>
          <R c="r" d="d3">
            <motion.div style={{ display: "flex", gap: 12, flexWrap: "wrap", marginBottom: 36 }} initial={{ opacity: 0 }} whileInView={{ opacity: 1 }} transition={{ staggerChildren: 0.2 }}>
              {[["₹4.2L", "Revenue today", "↑18.4%"], ["₹3.1L", "Net profit", "↑24.1%"], ["84/100", "Tax score", "Optimised"]].map(([v, l, d], i) => (
                <motion.div className="chip glow-hover" key={l} initial={{ y: 20, opacity: 0 }} whileInView={{ y: 0, opacity: 1 }} whileHover={{ y: -10 }} transition={{ delay: i * 0.1 }}>
                  <div className="chip-v">{v}</div>
                  <div className="chip-l">{l}</div>
                  <div className="chip-d">{d}</div>
                </motion.div>
              ))}
            </motion.div>
          </R>
          <R c="r" d="d4">
            <motion.div style={{ display: "flex", gap: 16, alignItems: "center", flexWrap: "wrap" }} initial={{ opacity: 0, y: 20 }} whileInView={{ opacity: 1, y: 0 }}>
              <motion.button className="btn btn-primary btn-lg ripple glow-hover" ref={useMagnetic()} whileHover={{ scale: 1.05, boxShadow: "0 12px 40px rgba(0,95,122,.5)" }} whileTap={{ scale: 0.98 }}>Start Free — ₹0</motion.button>
              <motion.button className="btn btn-ghost ripple" ref={useMagnetic()} whileHover={{ scale: 1.02, y: -4 }} whileTap={{ scale: 0.98 }}>
                <span style={{ width: 32, height: 32, borderRadius: "50%", border: "1.5px solid var(--border)", display: "flex", alignItems: "center", justifyContent: "center", fontSize: 13, color: "var(--primary)" }}>▷</span>
                Watch 90s demo
              </motion.button>
            </motion.div>
          </R>
        </motion.div>

        <R c="rs" d="d2" style={{ height: "100%", minHeight: 500 }}>
          <motion.div className="parallax" style={{ height: "100%", minHeight: 500 }}>
            <Ph label="Dashboard · Hero" num="01" type="dashboard" mockup={<HeroDashboard />} className="parallax-blend glow-hover">
              <div style={{ position: "absolute", bottom: 0, left: 0, right: 0, padding: "20px 24px", background: "linear-gradient(transparent, rgba(0,74,96,.92))", zIndex: 5, display: "flex", justifyContent: "space-between", alignItems: "flex-end", borderRadius: "0 0 var(--r-lg) var(--r-lg)" }}>
                <div>
                  <div style={{ fontFamily: "var(--font-mono)", fontSize: 8, color: "rgba(255,255,255,.55)", marginBottom: 4, letterSpacing: ".16em", textTransform: "uppercase" }}>Revenue · Q2 2025</div>
                  <motion.div className="glow-hover" style={{ fontFamily: "var(--font-head)", fontWeight: 800, fontSize: 30, color: "#fff", letterSpacing: "-.03em" }} whileHover={{ scale: 1.1 }}>₹42.8L</motion.div>
                </div>
                <motion.svg width="90" height="36" viewBox="0 0 90 36" initial={{ pathLength: 0 }} animate={{ pathLength: 1 }} transition={{ duration: 2, delay: 1 }}>
                  <polyline points="0,30 16,22 30,26 46,12 62,16 78,5 90,8" fill="none" stroke="white" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" strokeDasharray="200" />
                </motion.svg>
              </div>
            </Ph>
          </motion.div>
        </R>
      </div>

      <TransitionWrapper>
        <div className="city-strip">
          {["Mumbai", "Bangalore", "Delhi", "Chennai", "Hyderabad", "Pune"].map(c => (
            <motion.span key={c} className="city-name" whileHover={{ scale: 1.1, color: "var(--primary)" }}>{c}</motion.span>
          ))}
          <motion.span className="city-live" animate={{ scale: [1, 1.2, 1] }} transition={{ repeat: Infinity, duration: 2 }} >Live</motion.span>
        </div>
      </TransitionWrapper>
    </section>
  );
}

/* Enhanced Stats with counter motion */
function Stats() {
  const ref = useRef(null);
  const [vals, setVals] = useState([0, 0, 0, 0]);
  const tgts = [70, 5000, 98, 42];
  const isInView = useRef(false);

  useEffect(() => {
    const observer = new IntersectionObserver(([entry]) => {
      if (entry.isIntersecting && !isInView.current) {
        isInView.current = true;
        tgts.forEach((t, i) => {
          let c = 0;
          const step = t / 55;
          const id = setInterval(() => {
            c = Math.min(c + step, t);
            setVals(p => { const n = [...p]; n[i] = Math.round(c); return n; });
            if (c >= t) clearInterval(id);
          }, 20);
        });
      }
    });
    if (ref.current) observer.observe(ref.current);
    return () => observer.disconnect();
  }, []);

  const data = [
    { pre: "", suf: "%", lbl: "Reduction in\nmanual finance work" },
    { pre: "", suf: "+", lbl: "Businesses trust\nFynovo daily" },
    { pre: "", suf: "%", lbl: "Customer\nsatisfaction rate" },
    { pre: "₹", suf: "Cr", lbl: "Revenue processed\nthis year" },
  ];

  return (
    <motion.section ref={ref} className="stats-wrap" initial={{ opacity: 0 }} whileInView={{ opacity: 1 }} viewport={{ once: true }}>
      <div style={{ maxWidth: "var(--max)", margin: "0 auto" }}>
        <motion.div style={{ display: "grid", gridTemplateColumns: "repeat(4,1fr)" }} initial={{ opacity: 0, scale: 0.95 }} whileInView={{ opacity: 1, scale: 1 }} transition={{ staggerChildren: 0.1 }}>
          {data.map(({ pre, suf, lbl }, i) => (
            <motion.div key={i} style={{ padding: "72px 56px", borderRight: i < 3 ? "1px solid rgba(255,255,255,.1)" : "none" }} whileHover={{ scale: 1.02 }}>
              <motion.div className="stats-n glow-hover" animate={isInView.current ? { scale: [1, 1.1, 1] } : {}} transition={{ repeat: Infinity, duration: 2, delay: i * 0.2 }}>{pre}<motion.em>{vals[i].toLocaleString()}</motion.em>{suf}</motion.div>
              <motion.div className="stats-lbl" initial={{ opacity: 0 }} whileInView={{ opacity: 1 }}>{lbl}</motion.div>
            </motion.div>
          ))}
        </motion.div>
      </div>
    </motion.section>
  );
}

/* Features with stagger */
function Features() {
  const containerVariants = {
    hidden: { opacity: 0 },
    visible: {
      opacity: 1,
      transition: {
        staggerChildren: 0.1,
        delayChildren: 0.2
      }
    }
  };

  const itemVariants = {
    hidden: { opacity: 0, y: 30 },
    visible: { opacity: 1, y: 0, transition: { duration: 0.6 } }
  };

  return (
    <motion.section className="section" variants={containerVariants} initial="hidden" whileInView="visible" viewport={{ once: true }}>
      <div className="container">
        <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 88, alignItems: "start" }}>
          <motion.div variants={itemVariants}>
            <R c="r"><Eyebrow text="Platform" /></R>
            <R c="r" d="d1">
              <motion.h2 className="display" style={{ fontSize: "clamp(36px,4.5vw,62px)", marginBottom: 20 }} whileHover={{ scale: 1.02 }}>
                Built for the way<br />money{" "} <span className="text-gradient">actually</span><br />moves.
              </motion.h2>
            </R>
            <R c="r" d="d2">
              <motion.p className="body-md" style={{ maxWidth: 360, marginBottom: 40 }} whileHover={{ scale: 1.01 }} >Every feature is designed around the real financial pressures on Indian SMEs, freelancers, and digital entrepreneurs.</motion.p>
            </R>
            <R c="rs" d="d3">
              <Ph label="Platform Overview" num="04" type="dashboard" style={{ height: 300, width: "100%", marginBottom: 12 }} className="glow-hover" />
            </R>
            <R c="rs" d="d4">
              <Ph label="Mobile App View" num="05" type="phone" style={{ height: 180, width: "100%" }} />
            </R>
          </motion.div>
          <motion.div style={{ paddingTop: 8 }} variants={containerVariants}>
            {FEATS.map(({ n, t, b }, i) => (
              <motion.div key={n} className="feat-row ripple" variants={itemVariants} whileHover={{ scale: 1.02, background: "var(--primary-bg)" }}>
                <div className="feat-n">{n}</div>
                <div><div className="feat-t">{t}</div><div className="feat-b">{b}</div></div>
                <motion.div className="feat-a" animate={{ x: [0, 5, 0] }} transition={{ repeat: Infinity, duration: 1.5 }} whileHover={{ scale: 1.2 }}>→</motion.div>
              </motion.div>
            ))}
          </motion.div>
        </div>
      </div>
    </motion.section>
  );
}

