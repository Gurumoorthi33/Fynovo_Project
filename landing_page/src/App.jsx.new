/* HeroDashboard SVG (unchanged) */
const HeroDashboard = () => (/* full SVG same as original - abbreviated here for space */ <svg viewBox="0 0 400 268" fill="none" xmlns="http://www.w3.org/2000/svg" style={{ width: "90%", maxWidth: 400 }}>{/* all rects/polyline/circles same */}</svg>);

function Ph({ label = "Photo", num = "00", style = {}, type = "grid", src = null, mockup = null, children, className = '' }) {
  if (src) return (
    <motion.div className={`ph ${className}`} style={style} whileHover={{ scale: 1.02, rotateY: 5 }} transition={{ type: "spring", stiffness: 400, damping: 20 }}>
      <img src={src} alt={label} style={{ width: "100%", height: "100%", objectFit: "cover" }} />
      {children}
    </motion.div>
  );
  const Icon = PH_ICON[type] || PH_ICON.grid;
  return (
    <motion.div ref={useMagnetic()} className={`ph magnetic ${className}`} style={style} whileHover={{ scale: 1.02 }} transition={{ type: "spring" }}>
      <div className="ph-grid" />
      {mockup ? <div style={{ position: "relative", zIndex: 2, width: "100%", height: "100%", display: "flex", alignItems: "center", justifyContent: "center" }}>{mockup}</div> : <div className="ph-inner"><div className="ph-icon-wrap"><motion.div whileHover={{ scale: 1.2, rotate: 180 }}><Icon /></motion.div><div className="ph-label">{label}</div></div>}
      <div className="ph-c tl" /><div className="ph-c tr" />
      <div className="ph-c bl" /><div className="ph-c br" />
      <div className="ph-num">{num}</div>
      {children}
    </motion.div>
  );
}

function Eyebrow({ text }) {
  return (
    <motion.div className="eyebrow" initial={{ scaleX: 0 }} whileInView={{ scaleX: 1 }} viewport={{ once: true }} transition={{ duration: 0.8, delay: 0.2 }}>
      <div className="eyebrow-line" />
      <span className="label">{text}</span>
    </motion.div>
  );
}

/* NAV with scroll anim */
function Nav() {
  const [s, setS] = useState(false);
  useEffect(() => {
    const fn = () => setS(window.scrollY > 40);
    window.addEventListener("scroll", fn);
    return () => window.removeEventListener("scroll", fn);
  }, []);
  return (
    <motion.nav 
      className={`nav${s ? " s" : ""}`} 
      initial={{ y: -100 }} 
      animate={{ y: 0 }} 
      transition={{ type: "spring", stiffness: 300, damping: 30 }}
    >
      <motion.a href="#" className="nav-logo" whileHover={{ y: -4, scale: 1.05 }}>
        Fy<em>novo</em>
      </motion.a>
      <ul className="nav-links">
        {["Platform", "Pricing", "Integrations", "Journal"].map(l => (
          <motion.li key={l}><motion.a href="#" whileHover={{ x: 4, color: "var(--primary)" }}>{l}</motion.a></motion.li>
        ))}
      </ul>
      <motion.button className="btn btn-primary" whileHover={{ scale: 1.05, boxShadow: "0 8px 32px rgba(0,95,122,.4)" }} whileTap={{ scale: 0.98 }} ref={useMagnetic()}>
        Open Account →
      </motion.button>
    </motion.nav>
  );
}

/* Hero with parallax blobs */
